views:
  - name: Episodes
    type: table
    # sort:
    #   - property: title
    #     direction: asc
    filters:
      and:
        - file.inFolder("wiki/episodes/i")
    order:
      - title
      - 1ere_apparition_pour
      - compteur_d_ep
      - date
      - pnj_presents
      - saison
      - univers
